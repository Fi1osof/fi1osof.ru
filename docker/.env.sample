# COMPOSE_PROJECT_NAME=
# NETWORK_NAME=docker_default

# Supabase PostgreSQL
SUPABASE_DB_PASSWORD=your_supabase_password
SUPABASE_DB_NAME=postgres

# Database URL for Prisma
DATABASE_URL=postgresql://postgres:${SUPABASE_DB_PASSWORD}@supabase:5432/your-db-name

# App
JWT_SECRET=your-secret-key-change-in-production

# Traefik (prod only)
ACME_EMAIL=

# n8n
N8N_SECURE_COOKIE=false
N8N_ENCRYPTION_KEY=generate-with-openssl-rand-hex-16
N8N_BOOTSTRAP_ACTIVATE_WORKFLOWS=true
N8N_PERSONALIZATION_ENABLED=false
NODES_EXCLUDE=[]
N8N_CUSTOM_EXTENSIONS=./.n8n/custom

# false or number
# N8N_AGENT_MEMORY_SIZE=5

# KB and EX nodes (disabled by default)
# N8N_HAS_KNOWLEDGES_BASE_NODES=true
# HAS_EX_NODES=true
# N8N_HAS_TASKS_NODES=true

# GraphQL endpoint
GRAPHQL_ENDPOINT=http://localhost:4000/api


## Mail Server (docker-mailserver)
# FQDN for the mail server
# MAIL_HOSTNAME=mail.example.com       
# Primary mail domain
# MAIL_DOMAIN=example.com              
# SSL type: letsencrypt, manual, self-signed, or empty
# MAIL_SSL_TYPE=letsencrypt            
# Spam filter (+200-300 MB RAM)
# MAIL_ENABLE_SPAMASSASSIN=0           
# Antivirus scanner (+1-1.5 GB RAM)
# MAIL_ENABLE_CLAMAV=0                 
# Ban IPs after failed auth attempts
# MAIL_ENABLE_FAIL2BAN=0               
# Greylisting for spam reduction
# MAIL_ENABLE_POSTGREY=0               
# POP3 protocol (legacy, use IMAP instead)
# MAIL_ENABLE_POP3=0                   
# IMAP protocol for reading mail
# MAIL_ENABLE_IMAP=1                   
# Set to 1 to disable receiving mail (send only)
# MAIL_SMTP_ONLY=0                     
# Allow sending from docker network without auth
# MAIL_PERMIT_DOCKER=network
# Relay all outgoing mail through another server (format: [host]:port)
# DEFAULT_RELAY_HOST=[mailhog]:1025
# Path to mailserver config (Docker: /app/mailserver-config, Local: ./docker/mailserver/config)
# MAILSERVER_CONFIG_PATH=/app/mailserver-config
